{
  "build": {
    "preview": {
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
        
      },
      "env": {
        "APP_VARIANT": "preview"
      }
    },
    "releaseCandidate": {
      "android": {
        "buildType": "apk",
        "autoIncrement": true
      },
      "env": {
        "APP_VARIANT": "releaseCandidate"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "ios": {
        "autoIncrement": true
      }
    }
  },
  "cli": {
    "appVersionSource": "remote"
  }
}
